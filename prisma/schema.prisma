generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- ENUMS ---

enum Role {
  ADMIN
  VENDEDOR
  DESENVOLVEDOR
}

// Ajustado para volumes e unidades de Adega
enum Tamanho {
  ML_269
  ML_350
  ML_473
  ML_600
  ML_750
  LITRO_1
  LITRO_2
  UNIDADE
  MACO
  FARDO
  LATA
}

// Categorias específicas para Adega e Conveniência
enum Categoria {
  CERVEJA
  DESTILADO
  VINHO
  REFRIGERANTE
  ENERGETICO
  AGUA
  SUCO
  CIGARRO
  PETISCO
  GELO
  OUTRO
}

enum MetodoPagamento {
  PIX
  CARTAO_CREDITO
  CARTAO_DEBITO
  DINHEIRO
  FIADO
}

// --- MODELS ---

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(VENDEDOR)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendas    Venda[]

  @@map("users")
}

model Produto {
  id              String      @id @default(cuid())
  nome            String
  categoria       Categoria
  tamanho         Tamanho
  precoCusto      Decimal     @db.Decimal(10, 2)
  precoVenda      Decimal     @db.Decimal(10, 2)
  quantidade      Int         @default(0)
  estoqueMinimo   Int         @default(5)
  controlaEstoque Boolean     @default(true) // <--- NOVO CAMPO: Define se abate estoque na venda
  ativo           Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  vendas          Venda[]
  itensVenda      ItemVenda[]

  @@map("produtos")
}

model Venda {
  id              String          @id @default(cuid())
  
  vendedorId      String
  vendedor        User            @relation(fields: [vendedorId], references: [id])
  
  produtoId       String
  produto         Produto         @relation(fields: [produtoId], references: [id])
  
  quantidade      Int
  valorTotal      Decimal         @db.Decimal(10, 2)
  metodoPagamento MetodoPagamento @default(PIX)

  // --- CONEXÃO COM O DEVEDOR (FIADO) ---
  devedorId       String?
  devedor         Devedor?        @relation(fields: [devedorId], references: [id])
  
  createdAt       DateTime        @default(now())
  itens           ItemVenda[]

  @@map("vendas")
}

model ItemVenda {
  id         String  @id @default(cuid())
  vendaId    String
  venda      Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  produtoId  String
  produto    Produto @relation(fields: [produtoId], references: [id])
  quantidade Int
  precoUnit  Decimal @db.Decimal(10, 2)
  subtotal   Decimal @db.Decimal(10, 2)

  @@map("itens_venda")
}

model Devedor {
  id           String   @id @default(cuid())
  nome         String
  telefone     String?  
  saldoDevedor Decimal  @db.Decimal(10, 2) @default(0)
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendas       Venda[]

  @@map("devedores")
}